<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.ustadim_yeni.IpcController"
      alignment="TOP_CENTER" spacing="10" style="-fx-padding: 15;">

    <Button text="Ana Sayfaya Geri Dön" onAction="#goToAnasayfa"/>

    <Label text="İDARİ PARA CEZASI HESAPLAMA" style="-fx-font-weight: bold;"/>

    <HBox alignment="CENTER" spacing="15" style="-fx-padding: 10; -fx-border-color: lightgray; -fx-border-radius: 5;">
        <Label text="Hesaplanacak Kanun:" style="-fx-font-weight: bold;"/>
        <Button text="Kanun No: 5510" onAction="#loadKanun5510"/>
        <Button text="Kanun No: 6331" onAction="#loadKanun6331"/>
    </HBox>

    <StackPane fx:id="ipcContentPane" VBox.vgrow="ALWAYS" style="-fx-padding: 10;"/>

</VBox>